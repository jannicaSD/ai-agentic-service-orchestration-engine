{
  "expo": {
    "name": "AntiGravity",
    "slug": "AntiGravity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.AntiGravity",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AntiGravity needs microphone access to convert your speech into text.",
        "NSSpeechRecognitionUsageDescription": "AntiGravity uses speech recognition to turn your voice into a message."
      }
    },
    "android": {
      "permissions": ["RECORD_AUDIO"],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCC2OEcWzwCQ5n3ukcAG3RA1cHyLVGvDQ0"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.AntiGravity"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow AntiGravity to use the microphone for speech-to-text.",
          "speechRecognitionPermission": "Allow AntiGravity to use speech recognition for voice input.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox", "com.google.android.tts", "com.google.android.as"]
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7ae248fc-aca1-4e18-87d3-7ade0b43398d"
      }
    }
  }
}
